{
  "name": "nakama",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "apps/platform/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "bun install --cwd docs/website",
    "start": "bun run apps/server/dist/index.js",
    "dev": "bun run dev:web",
    "dev:server": "bun run apps/server/src/dev.ts",
    "dev:cli": "bun run apps/cli/src/index.ts",
    "dev:telegram": "bun run --filter @nakama/telegram dev",
    "dev:whatsapp": "bun run --filter @nakama/whatsapp dev",
    "dev:discord": "bun run --filter @nakama/discord dev",
    "dev:automation": "bun run --filter @nakama/automation dev",
    "dev:web": "bun run --filter @nakama/web dev",
    "dev:docs": "bun run --cwd docs/website dev",
    "build:docs": "bun run --cwd docs/website build",
    "preview:docs": "bun run --cwd docs/website preview",
    "build": "bun run --workspaces --if-present build",
    "test": "bun run --workspaces --if-present test",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3"
  },
  "overrides": {
    "libsignal": "6.0.0"
  }
}
